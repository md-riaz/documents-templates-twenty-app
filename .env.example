# Twenty API Configuration
# Get your API key from: Twenty → Settings → API → Create API key

# Your Twenty server URL (local or cloud)
TWENTY_API_URL=http://localhost:3000

# Your Twenty API key
TWENTY_API_KEY=your-api-key-here

# Logic function execution (required for this app's workflow-builder steps to run)
# Twenty's Render Template, Generate PDF, and Save Document workflow steps
# are logic functions. By default Twenty deployments set LOGIC_FUNCTION_TYPE=DISABLED,
# which means those steps will NOT execute. Change it to a real function-execution
# backend supported by your Twenty deployment — see Twenty's deployment docs at
# https://docs.twenty.com for the executor values valid for your version. Do not leave
# this unset/DISABLED in an environment where you expect workflows to actually run.
# LOGIC_FUNCTION_TYPE=DISABLED
